rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users: own profile read/write; Cloud Functions use Admin SDK (bypasses rules) ──
    match /users/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Volunteer presence: anyone authenticated can read (map); own write only ──
    match /volunteers/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── SOS Incidents: victim creates, all authenticated read, CF handles updates ──
    match /sos_incidents/{id} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if request.auth != null;
      // Victim and accepted volunteers can merge limited fields (e.g. volunteer location)
      allow update: if request.auth != null
                    && (
                      request.auth.uid == resource.data.userId
                      || request.auth.uid in (resource.data.acceptedVolunteerIds ?? [])
                    );
      allow delete: if false; // Cloud Functions handle archival only
    }

    // ── Incident archive: read-only; CF writes via Admin SDK ─────────────────
    match /sos_incidents_archive/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Hospital registry: read for authenticated; write via CF only ──────────
    match /ops_hospitals/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Hospital assignments: read for authenticated; CF writes only ──────────
    match /ops_incident_hospital_assignments/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Fleet units: read for authenticated; operators update heartbeat ───────
    match /ops_fleet_units/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Fleet assignment queues: operators read/respond to their queue ────────
    match /ops_fleet_assignments/{callSign}/pending/{docId} {
      allow read:  if request.auth != null;
      allow write: if false; // CF only
    }

    // ── PTT channels: any authenticated participant can read/post ─────────────
    match /ptt_channels/{incidentId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Leaderboard: public read; CF writes only ──────────────────────────────
    match /leaderboard/{uid} {
      allow read:  if true;
      allow write: if false;
    }

    // ── AED locations: public read; CF/webhook writes only ───────────────────
    match /aeds/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Ops dashboard alerts: authenticated read (admin UI); CF writes ─────────
    match /ops_dashboard_alerts/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Ops health metrics: authenticated read; CF increments ─────────────────
    match /ops_health_metrics/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── LiveKit bridge records: CF writes; participants read ──────────────────
    match /livekit_bridges/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /livekit_copilot_dispatches/{id} {
      allow read:  if request.auth != null && request.auth.uid == id;
      allow write: if false;
    }

    // ── Preparedness events / webhook log: authenticated read ─────────────────
    match /preparedness_events/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /webhook_events/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Lifeline response cache: CF reads/writes; no client write ─────────────
    match /lifeline_response_cache/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Default: deny everything not explicitly matched ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

